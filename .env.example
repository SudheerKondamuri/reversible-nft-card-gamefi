# Environment Configuration
# Copy this file to .env and fill in your values

# Network Configuration
HARDHAT_NETWORK=hardhat
CHAIN_ID=31337

# Contract Addresses (fill after deployment)
CARD_NFT_ADDRESS=0x
COMBINATION_MANAGER_ADDRESS=0x

# Account Configuration
DEPLOYER_PRIVATE_KEY=
ACCOUNT_1_PRIVATE_KEY=
ACCOUNT_2_PRIVATE_KEY=

# Etherscan Configuration (for verification)
ETHERSCAN_API_KEY=

# RPC Endpoints
MAINNET_RPC_URL=
SEPOLIA_RPC_URL=
POLYGON_RPC_URL=
ARBITRUM_RPC_URL=

# Game Economics
INITIAL_SUPPLY=1000000
FUSION_BASE_COST=1000
REWARD_MULTIPLIER=1.0

# Logging
LOG_LEVEL=info
DEBUG=false

# IPFS Configuration (if using)
IPFS_API_URL=http://localhost:5001
IPFS_GATEWAY_URL=https://gateway.pinata.cloud

# Backend Configuration (if applicable)
API_PORT=3000
API_HOST=localhost

# Frontend Configuration (if applicable)
REACT_APP_CHAIN_ID=31337
REACT_APP_RPC_URL=http://localhost:8545
REACT_APP_CONTRACT_ADDRESS=0x
